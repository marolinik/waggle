{
  "name": "waggle-poc",
  "version": "0.1.0",
  "description": "Your personal AI agent swarm — persistent memory, model-agnostic, skill-extensible",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/*",
    "sidecar"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "license": "MIT",
  "private": true,
  "keywords": [
    "ai",
    "agent",
    "swarm",
    "memory",
    "llm"
  ],
  "author": "Marko Markovic",
  "repository": {
    "type": "git",
    "url": "https://github.com/user/waggle.git"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.5",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
