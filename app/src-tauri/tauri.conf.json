{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Waggle",
  "version": "0.1.0",
  "identifier": "com.waggle.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "icon": ["icons/icon.ico"],
    "resources": [
      "resources/node/**",
      "resources/python/**"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "license": null,
        "shortDescription": "Waggle — Your AI Agent Swarm",
        "template": "nsis/installer.nsi"
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "Waggle",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* ws://localhost:*; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
