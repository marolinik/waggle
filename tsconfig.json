{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "references": [
    { "path": "packages/core" },
    { "path": "packages/agent" },
    { "path": "packages/optimizer" },
    { "path": "packages/weaver" },
    { "path": "packages/cli" },
    { "path": "packages/sdk" },
    { "path": "packages/shared" },
    { "path": "packages/server" },
    { "path": "packages/worker" },
    { "path": "packages/waggle-dance" }
  ],
  "include": [],
  "exclude": ["node_modules", "dist"]
}
